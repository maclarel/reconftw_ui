# Path to the directory containing per-domain ReconFTW output folders.
# Each subdirectory should be named after the domain (e.g. data/example.com/).
# Defaults to ./sampledata if not set.
DATA_DIR=./sampledata

# Flask secret key (used for sessions; change in production)
SECRET_KEY=change-me-in-production

# Address to bind the server to.
# Use 127.0.0.1 (default) for localhost-only access.
# Use 0.0.0.0 to listen on all interfaces (e.g. to expose on a LAN/public interface).
# A specific IP address can also be provided to bind to a single interface.
# This value is respected by both `flask run` and `python app.py`.
FLASK_RUN_HOST=127.0.0.1

# Port to listen on (default: 5000)
FLASK_RUN_PORT=5000

# Set to 1 to enable debug mode
FLASK_DEBUG=0
